{
  "name": "echtstern-extension",
  "version": "1.2.1",
  "description": "Open-source Chrome extension for contextualizing Google Maps ratings.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://echtstern.de",
  "bugs": {
    "url": "https://github.com/The-Nexus-Collective/echtstern-extension/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-Nexus-Collective/echtstern-extension.git"
  },
  "keywords": [
    "chrome-extension",
    "google-maps",
    "reviews",
    "ratings",
    "echtstern"
  ],
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:chrome",
    "build:chrome": "tsc -b && vite build && vite build --config vite.content.config.ts && vite build --config vite.background.config.ts",
    "build:firefox": "tsc -b && BROWSER_TARGET=firefox vite build && BROWSER_TARGET=firefox vite build --config vite.content.config.ts && BROWSER_TARGET=firefox vite build --config vite.background.config.ts",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:firefox": "web-ext lint --source-dir dist",
    "run:firefox": "web-ext run --source-dir dist",
    "package:firefox": "web-ext build --source-dir dist --artifacts-dir artifacts --overwrite-dest",
    "preview": "vite preview"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "html-to-image": "^1.11.13",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.40",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "web-ext": "^8.10.0"
  }
}
